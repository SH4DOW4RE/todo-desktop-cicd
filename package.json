{
  "name": "todo-desktop-cicd",
  "productName": "Todo Desktop CICD",
  "version": "1.0.14",
  "description": "A cross-platform Electron desktop client for managing todos, folders, tags, and account data.",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "start": "electron-forge start",
    "test": "node --test \"test/**/*.test.js\"",
    "coverage": "node --test --experimental-test-coverage --test-coverage-lines=90 --test-coverage-functions=90 --test-coverage-branches=90 --test-coverage-include=api/*.js \"test/**/*.test.js\"",
    "package": "electron-forge package",
    "make": "electron-forge make"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SH4DOW4RE/todo-desktop-cicd.git"
  },
  "keywords": [
    "electron",
    "todo",
    "desktop",
    "ci",
    "cd"
  ],
  "author": "SH4DOW4RE",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/SH4DOW4RE/todo-desktop-cicd/issues"
  },
  "homepage": "https://github.com/SH4DOW4RE/todo-desktop-cicd#readme",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron/fuses": "^1.8.0",
    "electron": "^42.4.1"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1"
  }
}
